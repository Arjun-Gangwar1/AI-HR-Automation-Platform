# ============================================
# AI HR Automation Platform — environment config
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
# ============================================

# ---- LLM PROVIDER (REQUIRED) ----
# Switch the AI backend with ONE line. Options: openai | groq | ollama | gemini | openrouter
#   openai -> uses OPENAI_API_KEY below (paid)
#   groq   -> FREE & fast: get a key at https://console.groq.com, paste GROQ_API_KEY,
#             then set  LLM_PROVIDER=groq
#   ollama -> 100% local/offline: run `ollama serve`; no key needed
#   gemini -> Google Gemini free tier: set GEMINI_API_KEY
#   openrouter -> set OPENROUTER_API_KEY
LLM_PROVIDER=openai
# Optional model override (else the provider default is used).
# LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=gsk-your-free-groq-key-here
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=

# ---- Email sending (REQUIRED for interview/onboarding/rejection emails) ----
# Use a Gmail App Password (not your normal password):
# Google Account > Security > 2-Step Verification > App passwords
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ---- Telegram job posting (REQUIRED for the posting agent) ----
# Create a bot via @BotFather to get the token; start a chat with it to get your chat ID.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# ---- Google Calendar (REQUIRED for interview scheduling) ----
# Download OAuth "Desktop app" credentials from Google Cloud Console as credentials.json.
# token.json is auto-created on first run after browser login. Both are gitignored.
CREDENTIALS_FILE=credentials.json
TOKEN_FILE=token.json
CALENDAR_ID=primary
TIMEZONE=Asia/Kolkata
HR_EMAIL=your_gmail@gmail.com

# ---- Tuning (optional; defaults shown) ----
MAX_SHORTLIST=5              # screening: max candidates to shortlist
SCREEN_LLM_TOP_K=5           # screening: only the top-K BERT-ranked resumes get deep LLM eval (rest are pre-screened)
APPLICATION_THRESHOLD=5      # posting: relax JD if applications < this
RELAXATION_INTERVAL_HOURS=48 # posting: how often to check + auto-relax the JD
APP_PORT=8000                # FastAPI server port
REMINDER_HOUR=8              # hour (local time) to send day-of interview reminders

# ---- Optional LangGraph conversational calendar agent (calendar_service/graph.py) ----
MODEL_NAME=gpt-4o
MAX_TOKENS=4096

# ---- LangSmith tracing for the AI Supervisor (Phase 3, optional) ----
# Set these to trace/debug/evaluate every supervisor run at https://smith.langchain.com
# (free tier available). Tracing turns on automatically when TRACING_V2=true — no code change.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-langsmith-key
# LANGCHAIN_PROJECT=hr-ai-supervisor

# ---- Unused (present in old code paths; safe to ignore) ----
# GROQ_API_KEY was referenced historically but the code now uses OpenAI only.
# GROQ_API_KEY=
